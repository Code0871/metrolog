qdrant_host=qdrant
qdrant_port_http=6333
qdrant_port_grpc=6334
collection_name=miinstance_park
qdrant_distance_type=Cosine
qdrant_vector_size=384
dense_count=25
sparse_count=25
multi_count=25

# Cервис моделей
host=0.0.0.0
port=8000
model_cache=./models_cache
log_level=info
debug=false
timeout=600
max_text_length=512
max_batch_size=100
bm25_index_path=./bm25_index.pkl
dense_embedding_model=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
sparse_model=qdrant/bm25
late_interaction_embedding_model=answerdotai/answerai-colbert-small-v1

# Сервис парка СИ
miinstance_host=service_park_app
miinstance_port=8080

